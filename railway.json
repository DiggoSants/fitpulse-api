{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "Nixpacks"
  },
  "deploy": {
    "preDeployCommand": "if [ -d src ]; then cd src; fi && php artisan migrate --force",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
